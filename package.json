{
  "name": "buildmarks",
  "version": "0.1.12",
  "description": "Public GitHub engineering signal cards for profile READMEs.",
  "license": "0BSD",
  "keywords": [
    "github",
    "profile-readme",
    "svg",
    "developer-tools",
    "oss",
    "0bsd",
    "maintenance",
    "github-actions"
  ],
  "homepage": "https://github.com/0disoft/buildmarks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/buildmarks.git"
  },
  "bugs": {
    "url": "https://github.com/0disoft/buildmarks/issues"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "docs",
    "examples",
    "fixtures",
    "action.yml",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "bun test",
    "test": "bun test",
    "build": "bun build src/index.ts src/cli/render-card.ts src/cli/render-github-artifacts.ts src/cli/render-github-card.ts src/cli/render-github-report.ts src/cli/render-gaps-card.ts src/cli/render-repo-card.ts src/cli/render-report.ts --outdir dist --target node",
    "build:card": "bun src/cli/render-card.ts fixtures/example-public-profile.json out/example-card.svg",
    "build:gaps-card": "bun src/cli/render-gaps-card.ts fixtures/example-public-profile.json out/example-gaps-card.svg",
    "build:repo-card": "bun src/cli/render-repo-card.ts fixtures/example-public-profile.json usable-toolkit out/example-repo-card.svg",
    "build:report": "bun src/cli/render-report.ts fixtures/example-public-profile.json out/report",
    "pack:dry-run": "npm pack --dry-run"
  }
}
